# Copy this file to .env and fill in real values for staging/production.
# Local dev works out of the box with zero changes (SQLite + mocked
# SMS/Mpesa).

# --- App ---
ENV=development
DEBUG=true

# --- Database ---
# Local dev (zero setup):
DATABASE_URL=sqlite:///./kejaflix.db
# Production (PostgreSQL + PostGIS):
# DATABASE_URL=postgresql+psycopg2://kejaflix:password@db:5432/kejaflix

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- OTP ---
OTP_EXPIRE_MINUTES=5
OTP_LENGTH=6
# MUST be false in production -- true only echoes the OTP in the API
# response for local testing without a real SMS provider.
OTP_DEBUG_ECHO=true

# --- Africa's Talking (SMS) ---
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=KEJAFLIX

# --- Safaricom Daraja (Mpesa) ---
# Leave MPESA_MOCK_MODE=true until you have sandbox/production Daraja
# credentials -- the unlock/payout flows work end-to-end in mock mode.
MPESA_MOCK_MODE=true
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
DARAJA_ENV=sandbox
DARAJA_CALLBACK_BASE_URL=https://api.kejaflix.com

SEARCH_UNLOCK_FEE_KES=250
FIELD_AGENT_REWARD_KES=500
FIELD_AGENT_MIN_PAYOUT_KES=500
FIELD_AGENT_DUPLICATE_RADIUS_M=20
FIELD_AGENT_GPS_ADDRESS_TOLERANCE_M=50

# --- Google Maps Platform ---
GOOGLE_MAPS_API_KEY=

# --- File storage ---
MEDIA_ROOT=./static
MEDIA_BASE_URL=http://localhost:8000/static
